{
  "AllowedHosts": "*",
  "Infrastructure": {
    "ApiBaseUrl": "",
    "ConnectionStrings": {
      "Postgres": ""
    }
  },
  "Telegram": {
    "AdminExternalId": null,
    "ApiBaseUrl": "https://api.telegram.org",
    "BotToken": "",
    "Webhook": {
      "SecretToken": "",
      "MaxConnections": 3,
      "RegistrationPeriodInMinutes": 10
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "ApplicationName": "Car Part Bot API"
    }
  }
}
